# =============================================================================
# 阿里云百炼 DashScope — OpenAI 兼容模式
# 文档: https://help.aliyun.com/zh/model-studio/developer-reference/compatibility-of-openai-with-dashscope
# =============================================================================

# 在百炼控制台创建 API Key: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# OpenAI 兼容端点（北京地域，一般无需修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# -----------------------------------------------------------------------------
# 模型选择（见下方说明）
# -----------------------------------------------------------------------------
# 【推荐 · 生产默认】均衡：诊断 + 规划 + 剧情 JSON，性价比最好
DASHSCOPE_MODEL=qwen-plus

# 可选方案（取消注释并注释掉上一行即可切换）：
# DASHSCOPE_MODEL=qwen3.5-plus    # 新一代 Plus，指令遵循/结构化输出通常更好（需控制台已开通）
# DASHSCOPE_MODEL=qwen-flash      # 开发调试 / 高并发：快且便宜，复杂语法诊断偏弱
# DASHSCOPE_MODEL=qwen-max        # 精品：诊断最稳，成本高，适合小班报告而非每次答题都调
# DASHSCOPE_MODEL=qwen3-max       # 旗舰推理，仅建议在 Plus 诊断明显不够时使用

# 是否启用 LLM 调度（false = 仅使用规则引擎，便于离线调试）
SWIGAR_LLM_ENABLED=true

# LLM 调用失败时是否回退到规则引擎
SWIGAR_LLM_FALLBACK_ON_ERROR=true

# 可选：请求超时（秒）。Plus/Max 首次调用可能较慢，可设为 90
DASHSCOPE_TIMEOUT=60

# =============================================================================
# 服务与数据库（与 TacticalDuel 游戏共用 Neon / PostgreSQL 即可）
# =============================================================================
# 游戏 .env 里常见的 postgresql:// 会自动转为 postgresql+asyncpg://（Agent API 异步访问）
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# 本地仅调试 Agent 事件/决策、不连云端时可改回 SQLite：
# DATABASE_URL=sqlite+aiosqlite:///./swigar.db

# 题库来源：auto=有 PostgreSQL URL 则从 questions_grammar / questions_words 加载
# 推荐生产/开发：先运行 python scripts/sync_question_bank.py，再设 json（秒级启动，不拉云端全表）
# postgres | json（data/question_bank.json）| builtin（4 道演示题）
SWIGAR_QUESTION_BANK_SOURCE=json

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5000,http://127.0.0.1:5000

# 记忆层：生产环境设为 false；无 onnxruntime 时可临时 true
SWIGAR_MEMORY_DISABLED=false

# MemPalace 本地向量嵌入（与百炼 LLM 无关）：cpu 即可，无需 GPU
MEMPALACE_EMBEDDING_DEVICE=cpu

# 组卷与答题并行：LLM 在线程池执行，不阻塞判题 API
SWIGAR_LLM_THREAD_WORKERS=2
# 首卷开始后延迟 N 秒再后台预生成下一卷（queued），避免与首卷抢 LLM
SWIGAR_PREFETCH_ON_SESSION_START=true
SWIGAR_PREFETCH_DELAY_SEC=30
SWIGAR_LLM_PREFETCH_WORKERS=2
# 若第 7 题时仍无 queued 卷，再触发一次预取（0=关闭）
SWIGAR_PREFETCH_FALLBACK_AT_QUESTION=7
# 变式题过生成候选数量（18–24 推荐）
SWIGAR_GENERATE_CANDIDATE_COUNT=20
# Generate step4 并行 lane 数（G1-G2 / G3-G4 / G5-G6）
SWIGAR_GENERATE_PARALLEL_LANES=3
# queued 卷超过 N 天则拆入 reserve 池再 hybrid 组卷
SWIGAR_QUEUED_MAX_AGE_DAYS=7
# reserve 题 TTL（天）；≥ SWIGAR_RESERVE_MIN_FOR_HYBRID 时走补卷而非全量 LLM
SWIGAR_RESERVE_TTL_DAYS=30
SWIGAR_RESERVE_MIN_FOR_HYBRID=4
# 交错组卷：DB 与 AI 题按 Q1–Q10 模板交替（默认 true）
SWIGAR_PAPER_INTERLEAVE=true
# 语义相似度 Phase2：embedding cosine（默认 false，仅用规则）
SWIGAR_SIMILARITY_EMBEDDING=false
# 6 道生成题中至少 N 道针对近期错题模式
SWIGAR_MIN_ERROR_TARGETED_GENERATED=3
# 卷内相近知识点混排（主 KP + 1–2 个同簇辅 KP，避免整卷同一题型）
SWIGAR_PAPER_KP_MIX=true
SWIGAR_MIN_DISTINCT_KP=2
SWIGAR_MAX_SAME_KP_RATIO=0.6
# 每卷 AI 生成阶段最多修订候选题次数（默认 2，避免 step6 串行过久导致前端 failed to fetch）
SWIGAR_MAX_REVISE_CANDIDATES=2
# true 时 MemPalace 写入也会刷工作流（默认 false，减少重复日志）
SWIGAR_VERBOSE_WORKFLOW=false
# 跨卷：近期答对题 ID 不再入选题库/reserve（天）
SWIGAR_EXCLUDE_RECENT_DAYS=14
# 同语法簇掌握度达标后下一卷换簇（0.0–1.0）
SWIGAR_KP_MASTERED_THRESHOLD=0.8
# 题库检索前打乱匹配候选（避免总抽到 JSON 前几条）
SWIGAR_RETRIEVE_SHUFFLE=true
